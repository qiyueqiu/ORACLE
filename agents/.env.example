# agents/.env.example — 后端 Agent 服务独立配置
# 加载顺序：根目录 .env → 当前目录 .env（后者的同名键会覆盖前者）

# ===== LLM =====
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# ===== 链连接 =====
PROVIDER_URL=http://localhost:8545
CHAIN_ID=31337

# ===== 合约地址 =====
AGENT_DID_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
AUDIT_LOG_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
REPUTATION_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# ===== 签名者私钥 =====
# Router：决策后对 (taskHash, rankedAgents, topAgent, ts) 签名上链（运营方/中继的合法职责）
# 新名 ROUTER_SIGNER_KEY 优先；未设则回退到旧名 ROUTER_SIGNER_PRIVATE_KEY
ROUTER_SIGNER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# 信誉分析：评分后写 Reputation
REPUTATION_SIGNER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# ===== P2 密钥分离：Worker 签名模式（修复 C1）=====
# 后端不再用单一密钥代所有 agent 签名。
#   demo  —— 本地/测试：worker 密钥由助记词按 agent 地址确定性派生
#   relay —— 生产：后端不持有 worker 密钥，转发 agent 端预签名（见 agents/TRUST-BOUNDARY.md）
WORKER_SIGNING_MODE=demo
# demo 模式 HD 助记词（默认 Hardhat 标准助记词；agent 地址 = 派生账户 = 链上 pubKey）
WORKER_DEMO_MNEMONIC=test test test test test test test test test test test junk

# ===== API Server =====
API_PORT=3001
# 访问密钥（多个用逗号分隔）。生产必须设置
API_ACCESS_KEYS=demo-key-change-me

# ===== 限流 =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ===== EIP-712 =====
EIP712_CHAIN_ID=31337
EIP712_DOMAIN_NAME=ORACLE Agent Bus
EIP712_DOMAIN_VERSION=1
