{
  "name": "oracle-agents",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ORACLE Agent 编排层（ESM + TypeScript）",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
