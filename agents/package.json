  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.0",
    "@types/supertest": "^6.0.0",
    "axios-mock-adapter": "^2.1.0",
    "chai": "^4.5.0",
    "eslint": "^9.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
