# ===== 根目录 .env.example =====
# 复制为 .env 后填入实际值

# Hardhat 节点（部署合约目标）
PROVIDER_URL=http://localhost:8545
CHAIN_ID=31337

# SiliconFlow LLM API（用于 Router/Worker/信誉分析）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 合约地址（deploy.js 部署后自动写入 addresses.json；
# 这里保留一份便于后端和脚本读取）
AGENT_DID_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
AUDIT_LOG_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
REPUTATION_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# Router 签名者（链上 auditSigner 的私钥）
# 注意：本地 Hardhat 演示专用；生产环境必须用 RouterRegistry 白名单的 EOA
ROUTER_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# 信誉分析签名者
REPUTATION_SIGNER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# API Server
API_PORT=3001
# API 访问密钥（生产必须设置；多值用逗号分隔）
API_ACCESS_KEYS=demo-key-change-me

# Worker 默认私钥（用于 EIP-712 签名执行结果）
# Worker 在 AgentDID 注册时绑定公钥，私钥保留在链下签名使用
# 演示环境用 Hardhat 内置账户；生产用 Agent 自己保管
WORKER_DEMO_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# 链 ID（EIP-712 防跨链重放）
EIP712_CHAIN_ID=31337
