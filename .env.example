# ===== 根目录 .env.example =====
# 复制为 .env 后填入实际值

# Hardhat 节点（部署合约目标）
PROVIDER_URL=http://localhost:8545
CHAIN_ID=31337

# SiliconFlow LLM API（用于 Router/Worker/信誉分析）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 合约地址（deploy.js 部署后自动写入 addresses.json；
# 这里保留一份便于后端和脚本读取）
AGENT_DID_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
AUDIT_LOG_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
REPUTATION_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# 审计写入模式（成本--可验证性帕累托前沿的部署选点）
#   full      —— 原版 AuditLog，13 字段全 SSTORE，~407k gas/dispatch（约 $24@20gwei,ETH=$3000）。
#                链上可 getRecord 回读、支持 dispute/slash、eth_getProof 无信任存在性证明。默认。
#   optimized —— AuditLogOptimized 的 M5 编码路径，event-only + recordId 编码归属零锚点，
#                ~85k gas/dispatch（省 ~79%，约 $5）。审计数据走 event（receipts trie 同等防篡改）；
#                代价：记录可发现性移到链下 indexer（EIP-7745/7792 前按 topic 检索需信任 RPC），
#                无链上回读 —— /api/reputation/summary 的记录统计降级。
AUDIT_MODE=full
# optimized 模式需填（deploy.js 部署后写入 deployments/<network>.json 的 AuditLogOptimized）
AUDIT_LOG_OPTIMIZED_ADDRESS=

# Router 签名者（链上 auditSigner 的私钥）
# 注意：本地 Hardhat 演示专用；生产环境必须用 RouterRegistry 白名单的 EOA
ROUTER_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# 信誉分析签名者
REPUTATION_SIGNER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# API Server
API_PORT=3001
# API 访问密钥（生产必须设置；多值用逗号分隔）
API_ACCESS_KEYS=demo-key-change-me

# Worker 签名（P2 密钥分离：后端是无特权中继，不用单一密钥代签所有 agent）
#   WORKER_SIGNING_MODE=demo  —— 本地/测试：worker 密钥由助记词按 agent 地址确定性派生
#   WORKER_SIGNING_MODE=relay —— 生产：后端不持有 worker 密钥，只转发 agent 预签名 payload
WORKER_SIGNING_MODE=demo
# demo 模式 HD 助记词（默认 Hardhat 标准助记词；必须是有效 BIP-39 短语）
WORKER_DEMO_MNEMONIC=test test test test test test test test test test test junk

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# 链 ID（EIP-712 防跨链重放）
EIP712_CHAIN_ID=31337
